# =============================================================================
# Portfolio V4 — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# GitHub Integration (Required for GitHub stats and projects sections)
# -----------------------------------------------------------------------------

# Your GitHub username (displayed publicly — safe to expose)
NEXT_PUBLIC_GITHUB_USERNAME=your_github_username

# GitHub Personal Access Token (for higher API rate limits: 5000 req/hr vs 60)
# Generate at: https://github.com/settings/tokens
# Required scopes: public_repo, read:user
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Site Configuration
# -----------------------------------------------------------------------------

# The canonical URL of your deployed site (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://yourportfolio.vercel.app

# Your full name (used in meta tags and structured data)
NEXT_PUBLIC_AUTHOR_NAME=Your Name

# Your professional title / tagline
NEXT_PUBLIC_AUTHOR_TITLE=Full-Stack Developer & UI Engineer

# Your email address (used in contact section)
NEXT_PUBLIC_CONTACT_EMAIL=hello@example.com

# -----------------------------------------------------------------------------
# Social Links (all optional — omit any you don't use)
# -----------------------------------------------------------------------------

NEXT_PUBLIC_GITHUB_URL=https://github.com/your_github_username
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/your_linkedin
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/your_twitter
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/your_instagram
NEXT_PUBLIC_YOUTUBE_URL=
NEXT_PUBLIC_DEVTO_URL=
NEXT_PUBLIC_MEDIUM_URL=

# -----------------------------------------------------------------------------
# Analytics (optional)
# -----------------------------------------------------------------------------

# Vercel Analytics (enable in Vercel dashboard, no key needed)
# NEXT_PUBLIC_VERCEL_ANALYTICS=true

# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Umami Analytics
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# NEXT_PUBLIC_UMAMI_URL=

# -----------------------------------------------------------------------------
# Contact Form (optional — only if you add a backend handler)
# -----------------------------------------------------------------------------

# Resend API key for sending contact form emails
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email address that receives contact form submissions
# CONTACT_FORM_TO_EMAIL=hello@example.com

# -----------------------------------------------------------------------------
# Feature Flags (optional)
# -----------------------------------------------------------------------------

# Set to "true" to enable Three.js 3D scenes (disable for performance testing)
NEXT_PUBLIC_ENABLE_3D=true

# Set to "true" to show the GitHub contribution calendar
NEXT_PUBLIC_ENABLE_GITHUB_CALENDAR=true

# Default locale for the site ("en" or "id")
NEXT_PUBLIC_DEFAULT_LOCALE=en
